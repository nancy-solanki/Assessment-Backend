# Production Environment Settings

DJANGO_ENV=production
SECRET_KEY="generate-a-very-secure-random-key-for-production"
DAILY_GOAL_KCAL=2000

# Production Database connection string (required)
DATABASE_URL="postgresql://username:password@ep-neon-db-identifierhost.aws.neon.tech/neondb?sslmode=require"

# CORS & Host settings
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Security configuration (Https enforcement)
SECURE_SSL_REDIRECT=True
